#!/usr/bin/env bash

set -euo pipefail

app_dir="${HOME}/.local/share/applications"
env_prefix="env GTK_IM_MODULE=cedilla QT_IM_MODULE=cedilla XMODIFIERS=@im=cedilla"
chrome_bin="/usr/bin/google-chrome-stable"

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

patch_desktop_file() {
  local source_file="$1"
  local target_file="$2"

  mkdir -p "${app_dir}"
  cp "${source_file}" "${target_file}"

  awk -v env_prefix="${env_prefix}" -v chrome_bin="${chrome_bin}" '
    /^Exec=/ {
      cmd = substr($0, 6)
      sub(/^env GTK_IM_MODULE=cedilla QT_IM_MODULE=cedilla XMODIFIERS=@im=cedilla /, "", cmd)
      gsub(/ --ozone-platform=[^ ]+/, "", cmd)
      sub(/^\/usr\/bin\/google-chrome-stable/, chrome_bin, cmd)
      sub(/^google-chrome-stable/, chrome_bin, cmd)
      if (cmd == chrome_bin) {
        cmd = chrome_bin " --ozone-platform=x11"
      } else if (index(cmd, chrome_bin " ") == 1) {
        cmd = chrome_bin " --ozone-platform=x11 " substr(cmd, length(chrome_bin) + 2)
      }
      print "Exec=" env_prefix " " cmd
      next
    }
    { print }
  ' "${target_file}" > "${target_file}.tmp"

  mv "${target_file}.tmp" "${target_file}"
}

main() {
  if [[ ! -x "${chrome_bin}" ]] && has_cmd google-chrome-stable; then
    chrome_bin="$(command -v google-chrome-stable)"
  fi

  local desktop_id source_file
  for desktop_id in google-chrome.desktop com.google.Chrome.desktop; do
    source_file="/usr/share/applications/${desktop_id}"
    if [[ -f "${source_file}" ]]; then
      patch_desktop_file "${source_file}" "${app_dir}/${desktop_id}"
    fi
  done

  if has_cmd update-desktop-database; then
    update-desktop-database "${app_dir}"
  fi
}

main "$@"
